{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "1232px",
			"wideSize": "1440px"
		},
		"typography": {
			"fontFamilies": [
				{
					"name": "System Sans-Serif",
					"slug": "system-sans-serif",
					"fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen-Sans, Ubuntu, Cantarell, 'Helvetica Neue', sans-serif"
				}
			],
			"fontSizes": [
				{
					"name": "Paragraph Small",
					"slug": "paragraph-small",
					"size": "0.875rem"
				},
				{
					"name": "Paragraph",
					"slug": "paragraph",
					"size": "clamp(0.975rem, 0.025vw + 0.968rem, 1rem)",
					"fluid": {
						"min": "0.975rem",
						"max": "1rem"
					}
				},
				{
					"name": "Paragraph Large",
					"slug": "paragraph-large",
					"size": "clamp(1rem, 0.14vw + 0.964rem, 1.125rem)",
					"fluid": {
						"min": "1rem",
						"max": "1.125rem"
					}
				},
				{
					"name": "Heading 4",
					"slug": "h4",
					"size": "clamp(1.25rem, 0.57vw + 1.07rem, 1.75rem)",
					"fluid": {
						"min": "1.25rem",
						"max": "1.75rem"
					}
				},
				{
					"name": "Heading 3",
					"slug": "h3",
					"size": "clamp(1.75rem, 0.57vw + 1.57rem, 2.25rem)",
					"fluid": {
						"min": "1.75rem",
						"max": "2.25rem"
					}
				},
				{
					"name": "Heading 2",
					"slug": "h2",
					"size": "clamp(2rem, 1.71vw + 1.45rem, 3.5rem)",
					"fluid": {
						"min": "2rem",
						"max": "3.5rem"
					}
				},
				{
					"name": "Heading 1",
					"slug": "h1",
					"size": "clamp(2.5rem, 2.73vw + 1.63rem, 4.875rem)",
					"fluid": {
						"min": "2.5rem",
						"max": "4.875rem"
					}
				}
			],
			"fluid": true
		},
		"color": {
			"palette": [
				{
					"name": "Primary",
					"slug": "primary",
					"color": "#A73C18"
				},
				{
					"name": "Secondary",
					"slug": "secondary",
					"color": "#F4EADB"
				},
				{
					"name": "Text",
					"slug": "text",
					"color": "#1B1C1B"
				},
				{
					"name": "White",
					"slug": "white",
					"color": "#FFFFFF"
				},
				{
					"name": "Black",
					"slug": "black",
					"color": "#000000"
				},
				{
					"name": "Transparent",
					"slug": "transparent",
					"color": "rgba(0,0,0,0)"
				},
				{
					"name": "Primary Muted 1",
					"slug": "primary-muted-1",
					"color": "#EDD8D1"
				},
				{
					"name": "Primary Muted 2",
					"slug": "primary-muted-2",
					"color": "#DCB1A3"
				},
				{
					"name": "Primary Muted 3",
					"slug": "primary-muted-3",
					"color": "#D39D8C"
				},
				{
					"name": "Primary Muted 4",
					"slug": "primary-muted-4",
					"color": "#C1775D"
				},
				{
					"name": "Primary Muted 5",
					"slug": "primary-muted-5",
					"color": "#B4593B"
				},
				{
					"name": "Primary Alpha 20",
					"slug": "primary-alpha-20",
					"color": "rgba(167,60,24,0.2)"
				},
				{
					"name": "Secondary Muted 1",
					"slug": "secondary-muted-1",
					"color": "#F0E4D5"
				},
				{
					"name": "Secondary Muted 2",
					"slug": "secondary-muted-2",
					"color": "#E6D5BF"
				},
				{
					"name": "Secondary Muted 3",
					"slug": "secondary-muted-3",
					"color": "#DBCAAB"
				},
				{
					"name": "Secondary Muted 4",
					"slug": "secondary-muted-4",
					"color": "#CCB891"
				},
				{
					"name": "Secondary Muted 5",
					"slug": "secondary-muted-5",
					"color": "#BAA078"
				},
				{
					"name": "Accent Success",
					"slug": "accent-success",
					"color": "#2D7A3E"
				},
				{
					"name": "Accent Error",
					"slug": "accent-error",
					"color": "#B83232"
				},
				{
					"name": "Accent Warning",
					"slug": "accent-warning",
					"color": "#CC8800"
				},
				{
					"name": "Accent Info",
					"slug": "accent-info",
					"color": "#2B6CB0"
				}
			]
		},
		"spacing": {
			"spacingScale": {
				"operator": "+",
				"increment": 1,
				"steps": 0
			},
			"spacingSizes": [
				{
					"name": "4",
					"slug": "4",
					"size": "0.25rem"
				},
				{
					"name": "8",
					"slug": "8",
					"size": "0.5rem"
				},
				{
					"name": "16",
					"slug": "16",
					"size": "clamp(0.75rem, 1vw + 0.5rem, 1rem)"
				},
				{
					"name": "24",
					"slug": "24",
					"size": "clamp(1rem, 1.5vw + 0.5rem, 1.5rem)"
				},
				{
					"name": "32",
					"slug": "32",
					"size": "clamp(1.25rem, 2vw + 0.625rem, 2rem)"
				},
				{
					"name": "40",
					"slug": "40",
					"size": "clamp(1.5rem, 2.5vw + 0.75rem, 2.5rem)"
				},
				{
					"name": "48",
					"slug": "48",
					"size": "clamp(1.75rem, 3vw + 0.875rem, 3rem)"
				},
				{
					"name": "56",
					"slug": "56",
					"size": "clamp(2rem, 3.5vw + 1rem, 3.5rem)"
				},
				{
					"name": "64",
					"slug": "64",
					"size": "clamp(2.25rem, 4vw + 1.125rem, 4rem)"
				},
				{
					"name": "72",
					"slug": "72",
					"size": "clamp(2.5rem, 4.5vw + 1.25rem, 4.5rem)"
				},
				{
					"name": "80",
					"slug": "80",
					"size": "clamp(2.75rem, 5vw + 1.375rem, 5rem)"
				},
				{
					"name": "88",
					"slug": "88",
					"size": "clamp(3rem, 5.5vw + 1.5rem, 5.5rem)"
				},
				{
					"name": "104",
					"slug": "104",
					"size": "clamp(3.5rem, 6.5vw + 1.75rem, 6.5rem)"
				}
			],
			"units": [
				"%",
				"px",
				"em",
				"rem",
				"vh",
				"vw"
			]
		},
		"blocks": {}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--white)",
			"text": "var(--wp--preset--color--text)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--system-sans-serif)",
			"fontSize": "var(--wp--preset--font-size--paragraph)",
			"lineHeight": "1.6"
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--32)"
		},
		"elements": {
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--h1)",
					"fontWeight": "700",
					"lineHeight": "1.1"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--h2)",
					"fontWeight": "700",
					"lineHeight": "1.2"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--h3)",
					"fontWeight": "600",
					"lineHeight": "1.3"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--h4)",
					"fontWeight": "600",
					"lineHeight": "1.4"
				}
			},
			"h5": {
				"typography": {
					"fontWeight": "600",
					"lineHeight": "1.4"
				}
			},
			"h6": {
				"typography": {
					"fontWeight": "600",
					"lineHeight": "1.4"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--primary-muted-5)"
					}
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--white)"
				},
				"typography": {
					"fontWeight": "600"
				},
				"border": {
					"radius": "4px"
				},
				"spacing": {
					"padding": {
						"top": "var(--wp--preset--spacing--16)",
						"bottom": "var(--wp--preset--spacing--16)",
						"left": "var(--wp--preset--spacing--32)",
						"right": "var(--wp--preset--spacing--32)"
					}
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--primary-muted-5)"
					}
				}
			}
		}
	},
	"customTemplates": [
		{
			"name": "index",
			"title": "Blog",
			"postTypes": [
				"page"
			]
		},
		{
			"name": "front-page",
			"title": "Front Page",
			"postTypes": [
				"page"
			]
		},
		{
			"name": "single",
			"title": "Single Post",
			"postTypes": [
				"post"
			]
		},
		{
			"name": "page",
			"title": "Page",
			"postTypes": [
				"page"
			]
		},
		{
			"name": "archive",
			"title": "Archive",
			"postTypes": [
				"page"
			]
		},
		{
			"name": "404",
			"title": "404",
			"postTypes": [
				"page"
			]
		},
		{
			"name": "search",
			"title": "Search",
			"postTypes": [
				"page"
			]
		}
	],
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	]
}
